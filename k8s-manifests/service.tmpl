apiVersion: v1
kind: Service
metadata:
  name: TOKEN_APP_NAME-service
  namespace: TOKEN_NAMESPACE
spec:
  selector:
    # This must perfectly match the labels defined in your deployment manifest
    app: TOKEN_APP_NAME
  ports:
    - protocol: TCP
      port: 8080        # The port exposed by the Service inside the cluster
      targetPort: 8080  # The port your Spring Boot app is listening on
  type: ClusterIP
